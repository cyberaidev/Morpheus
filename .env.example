# Copy to .env (gitignored). Morpheus never commits real secrets.
# These are read by adapters via ${ENV_VAR} placeholders / SDK credential chains.

# Generic HTTP adapter bearer token (referenced as ${AGENT_API_TOKEN}).
AGENT_API_TOKEN=

# OpenAI Assistants adapter.
OPENAI_API_KEY=

# AWS Bedrock uses the standard boto3 credential chain (AWS_PROFILE, etc.).
# AWS_PROFILE=
# AWS_REGION=us-east-1

# Azure uses DefaultAzureCredential (az login, managed identity, env vars).
# GCP Vertex uses Application Default Credentials (gcloud auth application-default login).
