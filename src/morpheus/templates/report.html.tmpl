<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Morpheus Report - {{TARGET_NAME}}</title>
<style>
:root { color-scheme: light dark; }
* { box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; margin: 0; padding: 0 1.5rem 3rem; color: #1a1a1a; background: #f7f7f9; }
h1, h2, h3 { color: #111; }
header { padding: 1.5rem 0 0.5rem; border-bottom: 2px solid #ddd; }
.subtitle { color: #666; font-size: 0.9rem; }
.gauge-wrap { margin: 1.5rem 0; }
.gauge-track { background: #e2e2e6; border-radius: 8px; height: 34px; width: 100%; overflow: hidden; }
.gauge-fill { height: 100%; color: #fff; font-weight: 700; display: flex; align-items: center; padding-left: 12px; border-radius: 8px 0 0 8px; }
.grade { font-size: 2.2rem; font-weight: 800; }
table { border-collapse: collapse; width: 100%; margin: 1rem 0; background: #fff; }
th, td { border: 1px solid #ddd; padding: 0.5rem 0.65rem; text-align: left; font-size: 0.9rem; vertical-align: top; }
th { background: #efeff3; }
.sev-critical { color: #b3001b; font-weight: 700; }
.sev-high { color: #d1491c; font-weight: 700; }
.sev-medium { color: #b8860b; font-weight: 600; }
.sev-low { color: #2a7f3f; }
.sev-info { color: #555; }
.pass { color: #1a7f37; font-weight: 700; }
.fail { color: #b3001b; font-weight: 700; }
.catbar-track { background: #e2e2e6; border-radius: 5px; height: 16px; width: 180px; display: inline-block; vertical-align: middle; overflow: hidden; }
.catbar-fill { height: 100%; background: #3a6ea5; border-radius: 5px; }
details { background: #fff; border: 1px solid #ddd; border-radius: 6px; margin: 0.5rem 0; padding: 0.5rem 0.75rem; }
summary { cursor: pointer; font-weight: 600; }
.excerpt { white-space: pre-wrap; background: #f0f0f3; padding: 0.5rem; border-radius: 4px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.8rem; overflow-x: auto; }
.kv { font-size: 0.85rem; margin: 0.25rem 0; }
footer { margin-top: 2rem; color: #888; font-size: 0.8rem; }
a { color: #3a6ea5; }
.filters { margin: 0.75rem 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
.filters button { cursor: pointer; border: 1px solid #bbb; background: #fff; border-radius: 6px; padding: 0.3rem 0.7rem; font-size: 0.8rem; color: #1a1a1a; }
.filters button.active { background: #3a6ea5; color: #fff; border-color: #3a6ea5; }
.finding.hidden { display: none; }
</style>
</head>
<body>
<header>
  <h1>Morpheus Security Report</h1>
  <div class="subtitle">Target: <strong>{{TARGET_NAME}}</strong> &middot; Pack: <strong>{{PACK_NAME}}</strong> &middot; Generated: {{GENERATED_AT}} &middot; Morpheus {{MORPHEUS_VERSION}}</div>
</header>

<section class="gauge-wrap">
  <div class="grade">Grade {{GRADE}} &mdash; {{OVERALL_SCORE}}/100</div>
  <div class="gauge-track">
    <div class="gauge-fill" style="width: {{OVERALL_SCORE}}%; background: {{GAUGE_COLOR}};">{{OVERALL_SCORE}}%</div>
  </div>
  <p class="kv">Scenarios: {{TOTAL_SCENARIOS}} &middot; Passed (secure): {{TOTAL_PASSED}} &middot; Failed (vulnerable): {{TOTAL_FAILED}} &middot; Errored (excluded): {{TOTAL_ERRORED}}</p>
</section>

<section>
  <h2>Failed findings</h2>
  <table>
    <thead><tr><th>Scenario</th><th>Severity</th><th>Title</th><th>ATLAS / OWASP</th><th>Remediation</th></tr></thead>
    <tbody>
{{FAILED_FINDINGS_ROWS}}
    </tbody>
  </table>
</section>

<section>
  <h2>Failed findings by severity</h2>
  <table>
    <thead><tr><th>Severity</th><th>Failed count</th></tr></thead>
    <tbody>
{{SEVERITY_ROWS}}
    </tbody>
  </table>
</section>

<section>
  <h2>Category scores</h2>
  <table>
    <thead><tr><th>Category</th><th>Score</th><th>Bar</th><th>Passed</th><th>Failed</th><th>Scored</th></tr></thead>
    <tbody>
{{CATEGORY_ROWS}}
    </tbody>
  </table>
</section>

<section>
  <h2>Findings</h2>
  <div class="filters" id="finding-filters">
    <button data-filter="all" class="active">All</button>
    <button data-filter="status:vulnerable">Vulnerable</button>
    <button data-filter="status:secure">Secure</button>
    <button data-filter="status:errored">Errored</button>
    <button data-filter="severity:critical">Critical</button>
    <button data-filter="severity:high">High</button>
    <button data-filter="severity:medium">Medium</button>
    <button data-filter="severity:low">Low</button>
    <button data-filter="severity:info">Info</button>
  </div>
  <div id="findings-list">
{{FINDINGS}}
  </div>
</section>

<script>
(function () {
  var filters = document.getElementById("finding-filters");
  if (!filters) { return; }
  var findings = document.querySelectorAll("#findings-list .finding");
  filters.addEventListener("click", function (ev) {
    var btn = ev.target.closest("button");
    if (!btn) { return; }
    var spec = btn.getAttribute("data-filter") || "all";
    filters.querySelectorAll("button").forEach(function (b) {
      b.classList.toggle("active", b === btn);
    });
    var parts = spec.split(":");
    var kind = parts[0];
    var value = parts[1];
    findings.forEach(function (el) {
      var show = true;
      if (kind === "status") {
        show = el.getAttribute("data-status") === value;
      } else if (kind === "severity") {
        show = el.getAttribute("data-severity") === value;
      }
      el.classList.toggle("hidden", !show);
    });
  });
})();
</script>

<footer>
  Techniques mapped to <a href="https://atlas.mitre.org/">MITRE ATLAS</a> and
  <a href="https://genai.owasp.org/">OWASP Top 10 for LLM Applications</a>.
  Report generated by Morpheus (MIT licensed).
</footer>
</body>
</html>
